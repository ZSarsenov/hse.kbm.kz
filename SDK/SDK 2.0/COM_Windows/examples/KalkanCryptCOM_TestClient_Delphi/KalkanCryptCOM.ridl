	[id(5008)] HRESULT SignData([in] BSTR alias, [in] INT flags, [in] BSTR inData, [out] BSTR* outSign);
	[id(5009)] HRESULT SignXML([in] BSTR alias, [in] INT flags, [in] BSTR signNodeId, [in] BSTR parentSignNode, [in] BSTR parentNameSpace, [in] BSTR inData, [out] BSTR* outSign);
	[id(5010)] HRESULT VerifyData([in] BSTR alias, [in] INT flags, [in] INT inCertID, [in] BSTR inData, [in] BSTR inSign, [out] BSTR* outData, [out] BSTR* outVerifyInfo, [out] BSTR* outCert);
	[id(5011)] HRESULT VerifyXML([in] BSTR alias, [in] INT flags, [in] BSTR inData, [out] BSTR* outVerifyInfo);
	[id(5012)] HRESULT GetLastError([out, retval] ULONG* rv);
	[id(5013)] HRESULT GetLastErrorString([out] BSTR* errorString, [out] ULONG* rv);
	[id(5014)] HRESULT GetSigAlgFromXML([in] BSTR inXML, [out] BSTR* outSigAlg);
	[id(5015)] HRESULT GetCertFromXML([in] BSTR inXML, [in] INT inSignID, [out] BSTR* outCert);
};
